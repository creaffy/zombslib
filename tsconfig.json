{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleResolution": "node16",
        "noImplicitAny": false,
        "paths": {
            "zombslib": ["./node_modules/zombslib"]
        }
    },
    "include": ["src"]
}
